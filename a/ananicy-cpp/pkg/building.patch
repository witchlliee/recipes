From 30277277c586d1c371f8b2602e8abdcbd878cb14 Mon Sep 17 00:00:00 2001
From: Kostadin Shishmanov <kostadinshishmanov@protonmail.com>
Date: Mon, 11 May 2026 11:54:13 +0300
Subject: [PATCH] Fix building with gcc 16

Looks like some stuff shuffled upstream and now the <unistd.h> header
needs to be explicitly included.

Signed-off-by: Kostadin Shishmanov <kostadinshishmanov@protonmail.com>
---
 src/platform/linux/debug.cpp     | 1 +
 src/platform/linux/process.cpp   | 1 +
 src/platform/systemd/service.cpp | 2 ++
 src/tests/unit-core.cpp          | 1 +
 src/tests/unit-cpuset.cpp        | 2 ++
 5 files changed, 7 insertions(+)

diff --git a/src/platform/linux/debug.cpp b/src/platform/linux/debug.cpp
index 1cbfb48..8c918e9 100644
--- a/src/platform/linux/debug.cpp
+++ b/src/platform/linux/debug.cpp
@@ -7,6 +7,7 @@
 #include <iostream>    // for cout
 #include <string>      // for string
 #include <string_view> // for string_view
+#include <unistd.h>    // for getpid
 
 #include <fmt/format.h>
 
diff --git a/src/platform/linux/process.cpp b/src/platform/linux/process.cpp
index d84cecf..652c41c 100644
--- a/src/platform/linux/process.cpp
+++ b/src/platform/linux/process.cpp
@@ -14,6 +14,7 @@
 #include <filesystem> // for path
 #include <fstream>    // for ifstream
 #include <thread>     // for jthread
+#include <unistd.h>   // for getpid
 
 #include <fmt/format.h>
 #include <fmt/ranges.h>
diff --git a/src/platform/systemd/service.cpp b/src/platform/systemd/service.cpp
index d716481..9fcde91 100644
--- a/src/platform/systemd/service.cpp
+++ b/src/platform/systemd/service.cpp
@@ -1,5 +1,7 @@
 #include "service.hpp"
 
+#include <unistd.h>
+
 #include <systemd/sd-daemon.h>
 #include <systemd/sd-login.h>
 
diff --git a/src/tests/unit-core.cpp b/src/tests/unit-core.cpp
index b71e033..b9db9a0 100644
--- a/src/tests/unit-core.cpp
+++ b/src/tests/unit-core.cpp
@@ -9,6 +9,7 @@
 
 #include <filesystem>
 #include <fstream>
+#include <unistd.h>
 
 #include <spdlog/spdlog.h>
 
diff --git a/src/tests/unit-cpuset.cpp b/src/tests/unit-cpuset.cpp
index 31ac770..540a231 100644
--- a/src/tests/unit-cpuset.cpp
+++ b/src/tests/unit-cpuset.cpp
@@ -4,6 +4,8 @@
 #include "core/cpuset.hpp"
 #include "core/x3d.hpp"
 
+#include <unistd.h>
+
 #include <spdlog/spdlog.h>
 
 TEST_SUITE_BEGIN("CpuSet");
-- 
GitLab

